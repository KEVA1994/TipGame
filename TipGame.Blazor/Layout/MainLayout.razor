@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider @bind-IsDarkMode="isDarkMode" Theme="appTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />
        <MudText Typo="Typo.h6" Class="ml-2">⚽ VM Tips Kuponen</MudText>
        <MudSpacer />

        @if (string.IsNullOrEmpty(PlayerState.PlayerName))
        {
            <MudIconButton Icon="@Icons.Material.Filled.Person"
                           Color="Color.Inherit"
                           OnClick="@(() => accountPopoverOpen = !accountPopoverOpen)" />
        }
        else
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small"
                     Icon="@Icons.Material.Filled.Person"
                     Text="@PlayerState.PlayerName"
                     OnClick="@(() => accountPopoverOpen = !accountPopoverOpen)" />
        }

        <TipGame.Blazor.Components.Account.AccountPopover @bind-IsOpen="accountPopoverOpen" />

        <MudIconButton Icon="@(isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode"/>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" OpenMiniOnHover="true">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Hjem
            </MudNavLink>
            <MudNavLink Href="matches" Icon="@Icons.Material.Filled.SportsSoccer">
                Kampe
            </MudNavLink>
            <MudNavLink Href="leaderboard" Icon="@Icons.Material.Filled.EmojiEvents">
                Stilling
            </MudNavLink>
            <MudNavLink Href="stats" Icon="@Icons.Material.Filled.BarChart">
                Statistik
            </MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pa-4">
        @Body
    </MudMainContent>
</MudLayout>
