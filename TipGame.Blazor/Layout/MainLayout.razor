@inherits LayoutComponentBase
@using MudBlazor

<MudThemeProvider @bind-IsDarkMode="isDarkMode" Theme="appTheme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="2" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="ToggleDrawer" />

        @if (CompetitionState.Current is not null)
        {
            <MudMenu @bind-Open="competitionMenuOpen" AnchorOrigin="Origin.BottomLeft" TransformOrigin="Origin.TopLeft">
                <ActivatorContent>
                    @* MudMenu's own click-to-open detection on custom ActivatorContent
                       is broken in this MudBlazor version — its ".mud-menu-activator"
                       wrapper renders with `display:contents`, collapsing its own
                       bounding box to zero, and the menu never opens no matter how
                       precisely the visible content is clicked (confirmed: content
                       renders fine once Open is set some other way — this is purely
                       an activation problem, a known class of MudBlazor issue).
                       Bypass it: drive Open ourselves from a plain @onclick instead
                       of relying on MudMenu's internal handling. *@
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1"
                              Style="cursor: pointer; padding: 6px 4px;"
                              @onclick="@(() => competitionMenuOpen = !competitionMenuOpen)">
                        <MudText Style="color: inherit; font-weight: 700;">@CompetitionState.Current.Name</MudText>
                        <MudIcon Icon="@Icons.Material.Filled.ArrowDropDown" Size="Size.Small" Style="color: inherit;" />
                    </MudStack>
                </ActivatorContent>
                <ChildContent>
                    @foreach (var comp in CompetitionState.MyCompetitions)
                    {
                        <MudMenuItem OnClick="@(() => CompetitionState.SetCurrentAsync(comp.Id))">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                                @if (comp.Id == CompetitionState.Current.Id)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" Color="Color.Primary" />
                                }
                                <MudText>@comp.Name</MudText>
                                @if (comp.Status != "active")
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">afsluttet</MudChip>
                                }
                            </MudStack>
                        </MudMenuItem>
                    }
                    <MudDivider />
                    <MudMenuItem Icon="@Icons.Material.Filled.Add" Href="opret">Opret ny konkurrence</MudMenuItem>
                </ChildContent>
            </MudMenu>
        }

        <MudSpacer />

        @if (string.IsNullOrEmpty(PlayerState.PlayerName))
        {
            <MudIconButton Icon="@Icons.Material.Filled.Person"
                           Color="Color.Inherit"
                           OnClick="@(() => accountPopoverOpen = !accountPopoverOpen)" />
        }
        else
        {
            <MudChip T="string" Color="Color.Secondary" Size="Size.Small"
                     Icon="@Icons.Material.Filled.Person"
                     Text="@PlayerState.PlayerName"
                     OnClick="@(() => accountPopoverOpen = !accountPopoverOpen)" />
        }

        <TipGame.Blazor.Components.Account.AccountPopover @bind-IsOpen="accountPopoverOpen" />

        <MudIconButton Icon="@(isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="ToggleDarkMode"/>
    </MudAppBar>

    <MudDrawer @bind-Open="drawerOpen" Elevation="2" ClipMode="DrawerClipMode.Always" Variant="DrawerVariant.Responsive" Breakpoint="Breakpoint.Md" OpenMiniOnHover="true">
        <MudNavMenu>
            <MudNavLink Href="" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                Hjem
            </MudNavLink>
            <MudNavLink Href="matches" Icon="@Icons.Material.Filled.SportsSoccer">
                Kampe
            </MudNavLink>
            <MudNavLink Href="leaderboard" Icon="@Icons.Material.Filled.EmojiEvents">
                Stilling
            </MudNavLink>
            <MudNavGroup Title="Statistik" Icon="@Icons.Material.Filled.BarChart" Expanded="true">
                <MudNavLink Href="stats?tab=0" Icon="@Icons.Material.Filled.TrendingUp">
                    Point-udvikling
                </MudNavLink>
                <MudNavLink Href="stats?tab=1" Icon="@Icons.Material.Filled.PieChart">
                    Træfsikkerhed
                </MudNavLink>
                <MudNavLink Href="stats?tab=2" Icon="@Icons.Material.Filled.BarChart">
                    Populære tips
                </MudNavLink>
                <MudNavLink Href="stats?tab=3" Icon="@Icons.Material.Filled.CalendarMonth">
                    Point per kampdag
                </MudNavLink>
                <MudNavLink Href="stats?tab=4" Icon="@Icons.Material.Filled.CompareArrows">
                    Head-to-head
                </MudNavLink>
            </MudNavGroup>
            <MudNavLink Href="praemier" Icon="@Icons.Material.Filled.WorkspacePremium">
                Præmier
            </MudNavLink>
            <MudNavLink Href="info" Icon="@Icons.Material.Filled.MenuBook">
                Info & regler
            </MudNavLink>
            @if (CompetitionState.IsAdmin)
            {
                <MudDivider Class="my-2" />
                <MudNavLink Href="admin" Icon="@Icons.Material.Filled.AdminPanelSettings">
                    Admin
                </MudNavLink>
            }
        </MudNavMenu>
    </MudDrawer>

    @* Padding lives on an inner div: putting pa-4 directly on MudMainContent would
       override (with !important) the padding-top MudBlazor adds to clear the fixed appbar. *@
    <MudMainContent>
        <div class="pa-4">
            @Body
        </div>
    </MudMainContent>
</MudLayout>
