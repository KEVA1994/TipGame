@page "/nulstil-kodeord"
@using MudBlazor

<MudStack Spacing="0" Class="mx-auto" Style="max-width: 480px;">

    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                       Color="Color.Default"
                       OnClick="@(() => Nav.NavigateTo(""))" />
        <MudText Typo="Typo.h4">🔑 Nulstil kodeord</MudText>
    </MudStack>

    @if (isLoading)
    {
        <MudPaper Class="pa-6 rounded-xl d-flex align-center justify-center" Elevation="1" Style="min-height: 200px;">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </MudPaper>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.ErrorOutline" Class="mb-4 rounded-xl">
            <MudText Typo="Typo.body2">@errorMessage</MudText>
        </MudAlert>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Home"
                   OnClick="@(() => Nav.NavigateTo(""))">
            Tilbage til forsiden
        </MudButton>
    }
    else if (isCompleted)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.CheckCircle" Class="mb-4 rounded-xl">
            <MudText Typo="Typo.body2">
                Dit kodeord er opdateret, og du er nu logget ind. Du bliver sendt videre om et øjeblik…
            </MudText>
        </MudAlert>
    }
    else
    {
        <MudPaper Class="pa-5 rounded-xl mb-4" Elevation="1">
            <MudStack Spacing="3">
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Vælg et nyt kodeord til din konto. Det skal være mindst 6 tegn.
                </MudText>

                <MudTextField @bind-Value="newPassword"
                              Label="Nyt kodeord"
                              InputType="InputType.Password"
                              Variant="Variant.Text"
                              Immediate="true"
                              OnKeyDown="HandleKey" />

                <MudTextField @bind-Value="confirmPassword"
                              Label="Bekræft nyt kodeord"
                              InputType="InputType.Password"
                              Variant="Variant.Text"
                              Immediate="true"
                              OnKeyDown="HandleKey" />

                @if (!string.IsNullOrEmpty(validationMessage))
                {
                    <MudText Typo="Typo.caption" Color="Color.Error">@validationMessage</MudText>
                }

                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Save"
                           OnClick="HandleSubmit"
                           Disabled="@(!CanSubmit)">
                    @(isSaving ? "Gemmer…" : "Gem nyt kodeord")
                </MudButton>
            </MudStack>
        </MudPaper>
    }

</MudStack>
