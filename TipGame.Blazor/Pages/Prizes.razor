@page "/praemier"
@using MudBlazor
@inject NavigationManager Nav

<MudStack Spacing="0" Class="mx-auto" Style="max-width: 1000px;">

    @* --- Header --- *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="@(() => Nav.NavigateTo(""))" />
        <MudText Typo="Typo.h4">🏅 Præmier</MudText>
    </MudStack>

    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Så er præmierne på plads! Her kan I se, hvad der venter de tre bedste. Held og lykke! 🏆
    </MudText>

    <MudGrid Spacing="4" Class="mb-6">

        @* --- 1. præmie --- *@
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-5 rounded-xl d-flex flex-column align-center" Elevation="3"
                      Style="height: 100%; background: linear-gradient(180deg, rgba(255,215,0,0.15) 0%, var(--mud-palette-surface) 100%);">
                <MudText Typo="Typo.h2">🥇</MudText>
                <MudText Typo="Typo.h6" Class="mt-1" Style="font-weight: 700;">1. præmie</MudText>

                <div class="d-flex align-center justify-center mt-3 mb-3 rounded-lg"
                     style="width: 100%; aspect-ratio: 1 / 1; overflow: hidden;">
                    <img src="images/prize-1.jpg" alt="1. præmie – gavekurv"
                         style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
                </div>

                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Style="font-style: italic;">
                    Lækker gavekurv med vin, chokolade og andre godter. 🎉
                </MudText>
            </MudPaper>
        </MudItem>

        @* --- 2. præmie --- *@
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-5 rounded-xl d-flex flex-column align-center" Elevation="2"
                      Style="height: 100%; background: linear-gradient(180deg, rgba(192,192,192,0.15) 0%, var(--mud-palette-surface) 100%);">
                <MudText Typo="Typo.h2">🥈</MudText>
                <MudText Typo="Typo.h6" Class="mt-1" Style="font-weight: 700;">2. præmie</MudText>

                <div class="d-flex align-center justify-center mt-3 mb-3 rounded-lg"
                     style="width: 100%; aspect-ratio: 1 / 1; overflow: hidden;">
                    <img src="images/prize-2.jpg" alt="2. præmie – gavekurv"
                         style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
                </div>

                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Style="font-style: italic;">
                    Lækker gavekurv med vin og andre godter. 🎉
                </MudText>
            </MudPaper>
        </MudItem>

        @* --- 3. præmie --- *@
        <MudItem xs="12" md="4">
            <MudPaper Class="pa-5 rounded-xl d-flex flex-column align-center" Elevation="1"
                      Style="height: 100%; background: linear-gradient(180deg, rgba(205,127,50,0.15) 0%, var(--mud-palette-surface) 100%);">
                <MudText Typo="Typo.h2">🥉</MudText>
                <MudText Typo="Typo.h6" Class="mt-1" Style="font-weight: 700;">3. præmie</MudText>

                <div class="d-flex align-center justify-center mt-3 mb-3 rounded-lg"
                     style="width: 100%; aspect-ratio: 1 / 1; overflow: hidden;">
                    <img src="images/prize-3.jpg" alt="3. præmie – gavekurv"
                         style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
                </div>

                <MudText Typo="Typo.caption" Align="Align.Center" Color="Color.Secondary" Style="font-style: italic;">
                    Lækker gavekurv med vin, øl og andre godter. 🎉
                </MudText>
            </MudPaper>
        </MudItem>

    </MudGrid>

    <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))">
        Tilbage til forsiden
    </MudButton>

</MudStack>
