@page "/praemier"
@using MudBlazor
@inject NavigationManager Nav
@inject CompetitionState CompetitionState
@implements IDisposable

<MudStack Spacing="0" Class="mx-auto" Style="max-width: 1000px;">

    @* --- Header --- *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-2">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Default" OnClick="@(() => Nav.NavigateTo(""))" />
        <MudText Typo="Typo.h4">🏅 Præmier</MudText>
    </MudStack>

    @if (!string.IsNullOrWhiteSpace(CompetitionState.Current?.PrizesText))
    {
        <MudPaper Class="pa-6 rounded-xl mb-6" Elevation="1"
                  Style="background: linear-gradient(135deg, rgba(255,215,0,0.08) 0%, rgba(192,192,192,0.05) 50%, rgba(205,127,50,0.08) 100%);">
            <TipGame.Blazor.Components.MarkdownView Content="@CompetitionState.Current!.PrizesText" />
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-8 rounded-xl mb-6 d-flex flex-column align-center" Elevation="1">
            <MudText Typo="Typo.h2">🤷</MudText>
            <MudText Typo="Typo.h6" Class="mt-2">Præmierne er ikke offentliggjort endnu</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center" Class="mt-1">
                @(CompetitionState.IsAdmin
                    ? "Du er admin — skriv præmieteksten under Admin → Præmie-tekst."
                    : "Spørg din admin, hvad der spilles om. Æren er der i hvert fald altid.")
            </MudText>
            @if (CompetitionState.IsAdmin)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Href="admin"
                           StartIcon="@Icons.Material.Filled.Edit">
                    Skriv præmietekst
                </MudButton>
            }
        </MudPaper>
    }

    <MudButton Variant="Variant.Text" Color="Color.Primary" StartIcon="@Icons.Material.Filled.ArrowBack" OnClick="@(() => Nav.NavigateTo(""))">
        Tilbage til forsiden
    </MudButton>

</MudStack>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        CompetitionState.OnChange += HandleChanged;
        await CompetitionState.InitializeAsync();
        StateHasChanged();
    }

    private void HandleChanged() => _ = InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        CompetitionState.OnChange -= HandleChanged;
    }
}
