@page "/stats"
@using MudBlazor
@using TipGame.Blazor.Components.Stats

<MudText Typo="Typo.h4" GutterBottom="true">📊 Statistik</MudText>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">@errorMessage</MudAlert>
}
else if (data is not null)
{
    <MudTabs Elevation="1" Rounded="false" Ripple="true" Color="Color.Primary" SliderColor="Color.Inherit" TabPanelsClass="pt-6"
             ActivePanelIndex="activeTab" ActivePanelIndexChanged="OnTabChanged" KeepPanelsAlive="true">

        <MudTabPanel Text="Point-udvikling" Icon="@Icons.Material.Filled.TrendingUp">
            <PointProgressionChart Series="@pointSeries" Labels="@pointLabels" />
        </MudTabPanel>

        <MudTabPanel Text="Træfsikkerhed" Icon="@Icons.Material.Filled.PieChart">
            <AccuracyChart Players="@data.Accuracy" />
        </MudTabPanel>

        <MudTabPanel Text="Populære tips" Icon="@Icons.Material.Filled.BarChart">
            <PopularTipsChart Tips="@data.PopularTips" />
        </MudTabPanel>

        <MudTabPanel Text="Point per kampdag" Icon="@Icons.Material.Filled.CalendarMonth">
            <MatchDayPointsChart Players="@players" MatchDays="@matchDays" MaxPointsByDay="@maxPointsByDay" />
        </MudTabPanel>

        <MudTabPanel Text="Head-to-head" Icon="@Icons.Material.Filled.CompareArrows">
            <HeadToHeadChart HeadToHead="@data.HeadToHead"
                             MatchIds="@data.MatchIds"
                             MatchLabels="@data.MatchLabels"
                             PlayerNames="@data.PlayerNames" />
        </MudTabPanel>

    </MudTabs>
}
