@page "/"
@using MudBlazor
@using TipGame.Shared.Models

@inject MatchService matchService
@inject LeaderboardService leaderboardService

<MudText Typo="Typo.h4" GutterBottom="true">⚽ Dashboard</MudText>

<MudText Typo="Typo.h6" Class="mb-2">Dagens kampe</MudText>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (todayMatches.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        No matches today. Better luck tomorrow.
    </MudAlert>
}
else
{
    <MudPaper Elevation="0" Class="rounded-lg mb-4" Style="overflow: hidden; border: 1px solid var(--mud-palette-lines-default);">
        @foreach (var match in todayMatches)
        {
            <div style="display: flex; align-items: center; padding: 8px 16px; border-bottom: 1px solid var(--mud-palette-lines-default);">
                <MudText Typo="Typo.caption" Style="width: 48px; text-align: center;" Color="@(match.Status == "FINISHED" ? Color.Error : Color.Default)">
                    @(match.Status == "FINISHED" ? "FT" : match.KickoffTime.ToString("HH:mm"))
                </MudText>
                <MudText Typo="Typo.body2" Style="flex: 1; padding: 0 12px;">
                    @match.HomeTeam vs @match.AwayTeam
                </MudText>
                <MudText Typo="Typo.body2" Style="font-weight: 700; width: 60px; text-align: center;">
                    @(match.HomeScore?.ToString() ?? "-") - @(match.AwayScore?.ToString() ?? "-")
                </MudText>
            </div>
        }
    </MudPaper>
}

<MudText Typo="Typo.h6" Class="mb-2">🏆 Top 3</MudText>

@if (topPlayers.Count == 0 && !isLoading)
{
    <MudText Typo="Typo.body2" Color="Color.Secondary">Ingen point endnu.</MudText>
}
else
{
    <MudPaper Elevation="0" Class="rounded-lg" Style="overflow: hidden; border: 1px solid var(--mud-palette-lines-default);">
        @for (var i = 0; i < topPlayers.Count; i++)
        {
            var player = topPlayers[i];
            var medal = i switch { 0 => "🥇", 1 => "🥈", 2 => "🥉", _ => "" };

            <div style="display: flex; align-items: center; padding: 10px 16px; border-bottom: 1px solid var(--mud-palette-lines-default);">
                <MudText Typo="Typo.h6" Style="width: 40px;">@medal</MudText>
                <MudText Typo="Typo.body1" Style="flex: 1;">@player.UserName</MudText>
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Text="@($"{player.TotalPoints} pts")" />
            </div>
        }
    </MudPaper>
}

@code {
    private List<MatchDto> todayMatches = new();
    private List<LeaderboardDto> topPlayers = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var matchesTask = matchService.GetMatches();
        var leaderboardTask = leaderboardService.GetLeaderboard();

        try
        {
            var allMatches = await matchesTask;
            todayMatches = allMatches
                .Where(m => m.KickoffTime.Date == DateTime.Today)
                .ToList();
        }
        catch { }

        try
        {
            var leaderboard = await leaderboardTask;
            topPlayers = leaderboard.Take(3).ToList();
        }
        catch { }

        isLoading = false;
    }
}
