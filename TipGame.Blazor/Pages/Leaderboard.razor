@page "/leaderboard"
@using MudBlazor
@using TipGame.Shared.Models

<MudText Typo="Typo.h4" GutterBottom="true">🏆 Leaderboard</MudText>

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (players.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Ingen point endnu.
    </MudAlert>
}
else
{
    @* --- Podium top 3 --- *@
    <MudPaper Class="pa-3 pa-sm-5 rounded-xl mb-5" Elevation="1">
        <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.End" Spacing="2" Class="podium">
            @if (players.Count > 1)
            {
                <div class="podium-col">
                    <MudText Typo="Typo.h5">🥈</MudText>
                    <MudAvatar Color="Color.Default" Size="Size.Medium" Variant="Variant.Filled">
                        @players[1].UserName[..1].ToUpper()
                    </MudAvatar>
                    <MudText Typo="Typo.body2" Class="podium-name">@players[1].UserName</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Default">@players[1].TotalPoints</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">point</MudText>
                    @if (players[1].CurrentStreak > 0)
                    {
                        <MudTooltip Text="Antal kampe i træk med point">
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">🔥 @players[1].CurrentStreak</MudChip>
                        </MudTooltip>
                    }
                    <div class="podium-bar podium-bar-silver"></div>
                </div>
            }

            <div class="podium-col podium-col-gold">
                <MudText Typo="Typo.h3">🥇</MudText>
                <MudAvatar Color="Color.Primary" Size="Size.Large" Variant="Variant.Filled">
                    @players[0].UserName[..1].ToUpper()
                </MudAvatar>
                <MudText Typo="Typo.h6" Class="podium-name">@players[0].UserName</MudText>
                <MudText Typo="Typo.h4" Color="Color.Primary">@players[0].TotalPoints</MudText>
                <MudText Typo="Typo.caption" Color="Color.Default">point</MudText>
                @if (players[0].CurrentStreak > 0)
                {
                    <MudTooltip Text="Antal kampe i træk med point">
                        <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">🔥 @players[0].CurrentStreak</MudChip>
                    </MudTooltip>
                }
                <div class="podium-bar podium-bar-gold"></div>
            </div>

            @if (players.Count > 2)
            {
                <div class="podium-col">
                    <MudText Typo="Typo.h5">🥉</MudText>
                    <MudAvatar Color="Color.Default" Size="Size.Medium" Variant="Variant.Filled">
                        @players[2].UserName[..1].ToUpper()
                    </MudAvatar>
                    <MudText Typo="Typo.body2" Class="podium-name">@players[2].UserName</MudText>
                    <MudText Typo="Typo.h6" Color="Color.Default">@players[2].TotalPoints</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">point</MudText>
                    @if (players[2].CurrentStreak > 0)
                    {
                        <MudTooltip Text="Antal kampe i træk med point">
                            <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">🔥 @players[2].CurrentStreak</MudChip>
                        </MudTooltip>
                    }
                    <div class="podium-bar podium-bar-bronze"></div>
                </div>
            }
        </MudStack>
    </MudPaper>

    @* --- Spillerkort --- *@
    <MudStack Spacing="2">
        @for (var i = 0; i < players.Count; i++)
        {
            var player = players[i];
            var rank = i + 1;
            var isTop3 = rank <= 3;
            var maxPoints = players[0].TotalPoints;
            var pct = maxPoints > 0 ? (double)player.TotalPoints / maxPoints * 100 : 0;
            var latestPts = !string.IsNullOrEmpty(latestDay) ? player.DailyPoints.GetValueOrDefault(latestDay) : 0;

            <MudPaper Class="pa-3 rounded-lg" Elevation="0" Outlined="true">
                <MudStack Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        @* Rank *@
                        <MudText Typo="Typo.subtitle2" Style="min-width: 28px; text-align: center;"
                                 Color="@(isTop3 ? Color.Primary : Color.Default)">
                            @(rank switch { 1 => "🥇", 2 => "🥈", 3 => "🥉", _ => $"{rank}." })
                        </MudText>

                        @* Avatar *@
                        <MudAvatar Color="@(isTop3 ? Color.Primary : Color.Default)"
                                   Size="Size.Small"
                                   Variant="@(isTop3 ? Variant.Filled : Variant.Outlined)">
                            @player.UserName[..1].ToUpper()
                        </MudAvatar>

                        @* Name + change *@
                        <MudStack Spacing="0" Style="flex: 1;" Class="card-name">
                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1">
                                <MudText Typo="Typo.body1" Class="card-name-text">@player.UserName</MudText>
                                @if (player.Change > 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Success" Size="Size.Small" />
                                    <MudText Typo="Typo.caption" Color="Color.Success">@player.Change</MudText>
                                }
                                else if (player.Change < 0)
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.ArrowDownward" Color="Color.Error" Size="Size.Small" />
                                    <MudText Typo="Typo.caption" Color="Color.Error">@Math.Abs(player.Change)</MudText>
                                }
                            </MudStack>
                            <MudText Typo="Typo.caption" Color="Color.Default" Class="card-sub">
                                @player.MatchesPlayed kampe · @player.AvgPoints pts pr kamp
                            </MudText>
                        </MudStack>

                        @* Total points *@
                        <MudText Typo="Typo.h6" Color="@(isTop3 ? Color.Primary : Color.Default)" Style="min-width: 50px; text-align: right;">
                            @player.TotalPoints
                        </MudText>
                    </MudStack>

                    @* Stats chips — egen række så navnet ikke bliver klemt *@
                    @if (player.ExactHits > 0 || player.CurrentStreak > 0 || latestPts > 0)
                    {
                        <MudStack Row="true" Spacing="1" Style="flex-wrap: wrap;">
                            @if (player.ExactHits > 0)
                            {
                                <MudTooltip Text="Antal resultater ramt lige på (3 point)">
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small">🎯 @player.ExactHits</MudChip>
                                </MudTooltip>
                            }
                            @if (player.CurrentStreak > 0)
                            {
                                <MudTooltip Text="Antal kampe i træk med point">
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Text" Size="Size.Small">🔥 @player.CurrentStreak</MudChip>
                                </MudTooltip>
                            }
                            @if (latestPts > 0)
                            {
                                <MudTooltip Text="@($"Point scoret på seneste kampdag ({latestDay})")">
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Filled" Size="Size.Small">+@latestPts</MudChip>
                                </MudTooltip>
                            }
                        </MudStack>
                    }

                    @* Progress bar *@
                    <MudProgressLinear Value="@pct"
                                       Color="@(isTop3 ? Color.Primary : Color.Default)"
                                       Rounded="true" Size="Size.Small" />
                </MudStack>
            </MudPaper>
        }
    </MudStack>
}