@page "/matches"
@using MudBlazor
@using TipGame.Blazor.Components
@using TipGame.Shared.Models

@inject MatchService matchService
@inject PredictionService predictionService
@inject PlayerState PlayerState

<MudText Typo="Typo.h4" GutterBottom="true">Kampe</MudText>

@if (string.IsNullOrEmpty(PlayerState.PlayerName))
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-2">
        Indtast dit navn øverst til højre for at tippe.
    </MudAlert>
}

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">
        @errorMessage
    </MudAlert>
}

<MudPaper Elevation="0" Class="rounded-lg" Style="overflow: hidden; border: 1px solid var(--mud-palette-lines-default);">
    <MudTable Items="matches" Hover="true" Breakpoint="Breakpoint.None" Elevation="0" Dense="true">
        <HeaderContent>
            <MudTh Style="width: 56px; text-align: center; font-weight: 700;">Tid</MudTh>
            <MudTh Style="width: 250px; font-weight: 700;">Hjemme</MudTh>
            <MudTh Style="width: 250px; font-weight: 700;">Ude</MudTh>
            <MudTh Style="width: 56px; text-align: center; white-space: nowrap; font-weight: 700;">Score</MudTh>
            <MudTh Style="width: 1%; white-space: nowrap; text-align: center; font-weight: 700;">Status</MudTh>
            @if (!string.IsNullOrEmpty(PlayerState.PlayerName))
            {
                <MudTh Style="font-weight: 700; white-space: nowrap; text-align: right; padding-right: 110px;">Tip</MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="text-align: center;">
                <MudStack Spacing="0" AlignItems="AlignItems.Center">
                    <MudText Typo="Typo.caption">@context.KickoffTime.ToString("dd/MM")</MudText>
                    <MudText Typo="Typo.caption">@context.KickoffTime.ToString("HH:mm")</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (!string.IsNullOrEmpty(context.HomeCrest))
                    {
                        <MudImage Src="@context.HomeCrest" Width="20" Height="20" ObjectFit="ObjectFit.Contain" />
                    }
                    <MudText Typo="Typo.body2">@context.HomeTeam</MudText>
                </MudStack>
            </MudTd>
            <MudTd>
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    @if (!string.IsNullOrEmpty(context.AwayCrest))
                    {
                        <MudImage Src="@context.AwayCrest" Width="20" Height="20" ObjectFit="ObjectFit.Contain" />
                    }
                    <MudText Typo="Typo.body2">@context.AwayTeam</MudText>
                </MudStack>
            </MudTd>
            <MudTd Style="text-align: center;">
                @if (context.Status == "IN_PLAY")
                {
                    <MudText Typo="Typo.body2" Color="Color.Primary" Style="font-weight: 700;">
                        @(context.HomeScore?.ToString() ?? "-") - @(context.AwayScore?.ToString() ?? "-")
                    </MudText>
                }
                else
                {
                    <MudText Typo="Typo.body2" Style="font-weight: 700;">
                        @(context.HomeScore?.ToString() ?? "-") - @(context.AwayScore?.ToString() ?? "-")
                    </MudText>
                }
            </MudTd>
            <MudTd Style="text-align: center; white-space: nowrap;">
                @if (context.Status == "FINISHED")
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Default" Text="FT" />
                }
                else if (context.Status == "IN_PLAY")
                {
                    <div style="display: inline-flex; align-items: center; gap: 6px;">
                        <span class="live-dot"></span>
                        <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight: 700; line-height: 1;">@(context.Minute != null ? $"{context.Minute}'" : "LIVE")</MudText>
                    </div>
                }
                else
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Text="Planlagt" />
                }
            </MudTd>
            @if (!string.IsNullOrEmpty(PlayerState.PlayerName))
            {
                <MudTd Style="text-align: right;">
                    <PredictionInput MatchId="@context.Id"
                                 Kickoff="@context.KickoffTime"
                                 PlayerName="@PlayerState.PlayerName"
                                 ExistingTip="@(tips.GetValueOrDefault(context.Id))"
                                 OnTipSaved="OnTipSaved" />
                </MudTd>
            }
        </RowTemplate>
    </MudTable>
</MudPaper>

@implements IDisposable

@code {
    private Dictionary<int, PredictionDto> tips = new();
    private List<MatchDto> matches = new();
    private bool isLoading = true;
    private string? errorMessage;
    private Timer? _refreshTimer;

    protected override void OnInitialized()
    {
        PlayerState.OnChange += OnPlayerChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await PlayerState.InitializeAsync();

        var matchesTask = matchService.GetMatches();

        Task<List<PredictionDto>>? tipsTask = null;
        if (!string.IsNullOrEmpty(PlayerState.PlayerName))
        {
            tipsTask = predictionService.GetPredictions(PlayerState.PlayerName);
        }

        try
        {
            matches = await matchesTask;
        }
        catch (Exception ex) when (ex is HttpRequestException or TaskCanceledException)
        {
            errorMessage = "Kunne ikke hente kampe. Tjek at API'et kører.";
        }

        if (tipsTask is not null)
        {
            try
            {
                var tipList = await tipsTask;
                tips = tipList.ToDictionary(t => t.MatchId);
            }
            catch { }
        }

        isLoading = false;
        StateHasChanged();

        _refreshTimer = new Timer(async _ => await RefreshLiveMatches(), null, TimeSpan.FromMinutes(2), TimeSpan.FromMinutes(2));
    }

    private async Task RefreshLiveMatches()
    {
        if (!matches.Any(m => m.Status == "IN_PLAY")) return;

        try
        {
            var updated = await matchService.GetMatches();
            foreach (var u in updated)
            {
                var existing = matches.FirstOrDefault(m => m.Id == u.Id);
                if (existing != null)
                {
                    existing.Status = u.Status;
                    existing.HomeScore = u.HomeScore;
                    existing.AwayScore = u.AwayScore;
                    existing.Minute = u.Minute;
                }
            }
            await InvokeAsync(StateHasChanged);
        }
        catch { }
    }

    private void OnTipSaved(PredictionDto tip)
    {
        tips[tip.MatchId] = tip;
    }

    private async void OnPlayerChanged()
    {
        if (!string.IsNullOrEmpty(PlayerState.PlayerName))
        {
            try
            {
                var tipList = await predictionService.GetPredictions(PlayerState.PlayerName);
                tips = tipList.ToDictionary(t => t.MatchId);
            }
            catch { }
        }
        else
        {
            tips = new();
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        _refreshTimer?.Dispose();
        PlayerState.OnChange -= OnPlayerChanged;
    }
}