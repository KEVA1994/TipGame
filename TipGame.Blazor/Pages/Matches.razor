@page "/matches"
@using MudBlazor
@using TipGame.Blazor.Components
@using TipGame.Shared.Models

@inject MatchService matchService
@inject PredictionService predictionService
@inject PlayerState PlayerState

<MudText Typo="Typo.h4" GutterBottom="true">Kampe</MudText>

@if (string.IsNullOrEmpty(PlayerState.PlayerName))
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-2">
        Indtast dit navn øverst til højre for at tippe.
    </MudAlert>
}

@if (isLoading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}

<MudPaper Elevation="0" Class="rounded-lg" Style="overflow: hidden; border: 1px solid var(--mud-palette-lines-default);">
    @foreach (var match in matches)
    {
        <div class="match-row">
            <div class="match-time">
                @if (match.Status == "FT")
                {
                    <span class="status-finished">FT</span>
                }
                else
                {
                    <span>@match.KickoffTime.ToString("dd/MM")</span>
                    <span>@match.KickoffTime.ToString("HH:mm")</span>
                }
            </div>

            <div class="match-teams">
                <span class="team-name">@match.HomeTeam</span>
                <span class="team-name">@match.AwayTeam</span>
            </div>

            <div class="match-score">
                <span>@(match.HomeScore?.ToString() ?? "-")</span>
                <span>@(match.AwayScore?.ToString() ?? "-")</span>
            </div>

            <div class="match-tip">
                <PredictionInput MatchId="@match.Id"
                                 Kickoff="@match.KickoffTime"
                                 ClientId="@PlayerState.ClientId"
                                 PlayerName="@PlayerState.PlayerName"
                                 ExistingTip="@(tips.GetValueOrDefault(match.Id))" />
            </div>
        </div>
    }
</MudPaper>

@code {
    private Dictionary<int, PredictionDto> tips = new();
    private List<MatchDto> matches = new();
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await PlayerState.InitializeAsync();

        var matchesTask = matchService.GetMatches();

        Task<List<PredictionDto>>? tipsTask = null;
        if (!string.IsNullOrEmpty(PlayerState.PlayerName))
        {
            tipsTask = predictionService.GetPredictions(PlayerState.ClientId);
        }

        try
        {
            matches = await matchesTask;
        }
        catch { }

        if (tipsTask is not null)
        {
            try
            {
                var tipList = await tipsTask;
                tips = tipList.ToDictionary(t => t.MatchId);
            }
            catch { }
        }

        isLoading = false;

        PlayerState.OnChange += OnPlayerChanged;
    }

    private async void OnPlayerChanged()
    {
        if (!string.IsNullOrEmpty(PlayerState.ClientId))
        {
            try
            {
                var tipList = await predictionService.GetPredictions(PlayerState.ClientId);
                tips = tipList.ToDictionary(t => t.MatchId);
            }
            catch { }
        }

        await InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        PlayerState.OnChange -= OnPlayerChanged;
    }
}