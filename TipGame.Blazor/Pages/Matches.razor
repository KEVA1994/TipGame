@page "/matches"
@using MudBlazor
@using TipGame.Shared.Models

<MudStack Spacing="0" Class="mx-auto" Style="max-width: 900px;">

    @* Header with title and filter tabs *@
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">

        @if (liveCount > 0)
        {
            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Filled">
                <span class="live-dot mr-1" style="width:6px;height:6px;"></span> @liveCount LIVE
            </MudChip>
        }
    </MudStack>

    @if (!PlayerState.IsLoggedIn)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Dense="true" Class="mb-3" Icon="@Icons.Material.Filled.Login">
            Log ind øverst til højre for at tippe på kampene.
        </MudAlert>
    }

    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mb-3 rounded-lg" Icon="@Icons.Material.Filled.Schedule">
        <MudText Typo="Typo.body2">
            <strong>Bemærk:</strong> Indtil videre er det kun <strong>gruppespillet</strong> der ligger klar at tippe på.
            Når vi kommer videre til slutspillet, bliver de nye kampe automatisk synlige her — så hold øje! 🏆
        </MudText>
    </MudAlert>

    <MudTabs ActivePanelIndex="activeTab" ActivePanelIndexChanged="OnTabChanged" Elevation="0" Rounded="true" ApplyEffectsToContainer="true"
             Class="mb-4" MinimumTabWidth="0px" PanelClass="pa-0">
        <MudTabPanel Text="Alle" BadgeColor="Color.Primary" />
        <MudTabPanel Text="I dag" BadgeColor="Color.Primary" />
        <MudTabPanel Text="Kommende" />
        <MudTabPanel Text="Afsluttede" />
        <MudTabPanel Text="Live" Disabled="@(liveCount == 0)" BadgeColor="Color.Error" BadgeDot="@(liveCount > 0)" />
    </MudTabs>

    @if (isLoading)
    {
        <MudStack Spacing="2" Class="mt-4">
            @for (var i = 0; i < 4; i++)
            {
                <MudSkeleton SkeletonType="SkeletonType.Rectangle" Height="52px" Class="rounded-lg" />
            }
        </MudStack>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-2">
            @errorMessage
        </MudAlert>
    }
    else if (!FilteredGroups.Any())
    {
        <MudStack AlignItems="AlignItems.Center" Class="mt-8 mb-8">
            <MudIcon Icon="@Icons.Material.Outlined.SportsScore" Size="Size.Large" Color="Color.Default" />
            <MudText Typo="Typo.body1" Color="Color.Secondary">Ingen kampe at vise.</MudText>
        </MudStack>
    }
    else
    {
        @foreach (var group in FilteredGroups)
        {
            <MudExpansionPanels MultiExpansion="true" Elevation="0" Class="mb-3">
                <MudExpansionPanel @bind-Expanded="expandedStates[group.GroupKey]" Dense="true" Class="rounded-lg"
                                   Style="border: 1px solid var(--mud-palette-lines-default);">
                    <TitleContent>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">@FormatGroupName(group.GroupKey)</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default">
                                @group.Rounds.Sum(r => r.Matches.Count) kampe
                            </MudChip>
                            @{
                                var groupLive = group.Rounds.Sum(r => r.Matches.Count(m => m.Status is "IN_PLAY" or "PAUSED"));
                            }
                            @if (groupLive > 0)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">
                                    @groupLive live
                                </MudChip>
                            }
                        </MudStack>
                    </TitleContent>
                    <ChildContent>
                        @foreach (var round in group.Rounds)
                        {
                            @* Group matches by date *@
                            @foreach (var dateGroup in round.Matches.GroupBy(m => m.KickoffTime.Date).OrderBy(d => d.Key))
                            {
                                @if (activeTab != 1)
                                {
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 mb-1 ml-1"
                                             Style="text-transform: uppercase; letter-spacing: 0.05em;">
                                        @FormatDate(dateGroup.Key)
                                    </MudText>
                                }

                                @foreach (var match in dateGroup)
                                {
                                    var isLive = match.Status is "IN_PLAY" or "PAUSED";
                                    var isFinished = match.Status == "FINISHED";
                                    var tip = tips.GetValueOrDefault(match.Id);
                                    var rowClass = "match-row" + (isLive ? " match-row-live" : "");

                                    <div class="@rowClass">
                                        @* Time / Status column *@
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center" Class="match-time">
                                            @if (isFinished)
                                            {
                                                <MudText Typo="Typo.caption" Style="font-weight: 600;">FT</MudText>
                                            }
                                            else if (isLive)
                                            {
                                                <span class="live-dot"></span>
                                                <MudText Typo="Typo.caption" Color="Color.Primary" Style="font-weight: 600;">
                                                    @(match.Status == "PAUSED" ? "HT" : match.Minute != null ? $"{match.Minute}'" : "LIVE")
                                                </MudText>
                                            }
                                            else
                                            {
                                                <MudText Typo="Typo.caption">@match.KickoffTime.ToString("HH:mm")</MudText>
                                            }
                                        </MudStack>

                                        @* Teams *@
                                        <MudStack Spacing="0" Class="match-teams">
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="match-team-line">
                                                @if (!string.IsNullOrEmpty(match.HomeCrest))
                                                {
                                                    <MudImage Src="@match.HomeCrest" Width="20" Height="20" ObjectFit="ObjectFit.Contain" />
                                                }
                                                <MudText Typo="Typo.body2" Style="@(isFinished && match.HomeScore > match.AwayScore ? "font-weight:700;" : "")">
                                                    @match.HomeTeam
                                                </MudText>
                                            </MudStack>
                                            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="match-team-line">
                                                @if (!string.IsNullOrEmpty(match.AwayCrest))
                                                {
                                                    <MudImage Src="@match.AwayCrest" Width="20" Height="20" ObjectFit="ObjectFit.Contain" />
                                                }
                                                <MudText Typo="Typo.body2" Style="@(isFinished && match.AwayScore > match.HomeScore ? "font-weight:700;" : "")">
                                                    @match.AwayTeam
                                                </MudText>
                                            </MudStack>
                                        </MudStack>

                                        @* Score *@
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center" Justify="Justify.Center" Class="match-score">
                                            @{
                                                var scoreStyle = isLive ? "font-weight:700;" : isFinished ? "font-weight:600;" : "";
                                                var scoreColor = isLive ? Color.Primary : Color.Default;
                                            }
                                            <MudText Typo="Typo.body2" Color="@scoreColor" Style="@scoreStyle">@(match.HomeScore?.ToString() ?? "-")</MudText>
                                            <MudText Typo="Typo.body2" Color="@scoreColor" Style="@scoreStyle">@(match.AwayScore?.ToString() ?? "-")</MudText>
                                        </MudStack>

                                        @if (PlayerState.IsLoggedIn)
                                        {
                                            <div class="match-divider"></div>

                                            @if (isFinished && tip is not null)
                                            {
                                                @* Finished match with a tip — show result chip *@
                                                <div class="match-tip-area">
                                                    @{
                                                        var points = CalculatePoints(match, tip);
                                                        var chipColor = points == 3 ? Color.Success : points == 1 ? Color.Warning : Color.Error;
                                                        var chipIcon = points == 3 ? Icons.Material.Filled.CheckCircle : points == 1 ? Icons.Material.Filled.RemoveCircle : Icons.Material.Filled.Cancel;
                                                    }
                                                    <MudTooltip Text="@($"Dit tip: {tip.HomeScore}-{tip.AwayScore} ({points} point)")">
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="@chipColor" Icon="@chipIcon">
                                                            @tip.HomeScore-@tip.AwayScore
                                                        </MudChip>
                                                    </MudTooltip>
                                                </div>
                                            }
                                            else if (CanEdit(match))
                                            {
                                                @* Editable prediction — compact inline *@
                                                var state = GetTipState(match.Id);
                                                <div class="match-tip-area">
                                                    <MudStack Spacing="0" AlignItems="AlignItems.Center" Class="match-score">
                                                        @if (tip is not null)
                                                        {
                                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@tip.HomeScore</MudText>
                                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@tip.AwayScore</MudText>
                                                        }
                                                        else
                                                        {
                                                            <input type="number" min="0" max="20"
                                                                   @bind="state.Home" @bind:event="oninput" @bind:after="@(() => TryAutoSaveTip(match.Id, state))"
                                                                   id="@($"tip-home-{match.Id}")"
                                                                   @onkeydown="@(e => HandleTipKeyDown(e, match.Id, state, isHome: true))"
                                                                   class="tip-inline-input" placeholder="-" />
                                                            <input type="number" min="0" max="20"
                                                                   @bind="state.Away" @bind:event="oninput" @bind:after="@(() => TryAutoSaveTip(match.Id, state))"
                                                                   id="@($"tip-away-{match.Id}")"
                                                                   @onkeydown="@(e => HandleTipKeyDown(e, match.Id, state, isHome: false))"
                                                                   class="tip-inline-input" placeholder="-" />
                                                        }
                                                    </MudStack>
                                                    @if (tip is not null)
                                                    {
                                                        <MudTooltip Text="Slet tip og lav et nyt">
                                                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                           Color="Color.Error" OnClick="@(() => DeleteTip(match.Id))" />
                                                        </MudTooltip>
                                                    }
                                                    else
                                                    {
                                                        @* Invisible spacer so editable rows align with rows that show the delete icon *@
                                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                                       Style="visibility:hidden;" tabindex="-1" aria-hidden="true" />
                                                    }
                                                </div>
                                            }
                                            else
                                            {
                                                @* Not editable (live or locked) *@
                                                <div class="match-tip-area">
                                                    @if (tip is not null)
                                                    {
                                                        <MudStack Spacing="0" AlignItems="AlignItems.Center" Class="match-score">
                                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@tip.HomeScore</MudText>
                                                            <MudText Typo="Typo.body2" Style="font-weight:600;">@tip.AwayScore</MudText>
                                                        </MudStack>
                                                        <MudIcon Icon="@Icons.Material.Filled.Lock" Size="Size.Small" Color="Color.Default" Class="ml-1" Style="opacity:0.4;" />
                                                    }
                                                    else
                                                    {
                                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default" Icon="@Icons.Material.Outlined.Block">
                                                            Intet tip
                                                        </MudChip>
                                                    }
                                                </div>
                                            }
                                        }
                                    </div>
                                }
                            }
                        }
                    </ChildContent>
                </MudExpansionPanel>
            </MudExpansionPanels>
        }
    }

</MudStack>
