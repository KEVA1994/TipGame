@using MudBlazor
@using TipGame.Shared.Models
@inject PredictionService PredictionService

<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center"
          Style="@($"width: 180px; justify-content: flex-end; margin-left: auto;{(isSaved && CanEdit ? " background-color: rgba(76, 175, 80, 0.12); border-radius: 4px; padding: 4px 0px 4px 8px;" : "")}")">

    <MudNumericField @bind-Value="home" Min="0" Max="20"
                     Style="width: 52px;"
                     Margin="Margin.Dense"
                     Variant="Variant.Text"
                     HideSpinButtons="true"
                     Immediate="true"
                     ReadOnly="@IsReadOnly"
                     Class="@(isSaved && !isEditing ? "tip-field tip-saved" : "tip-field")" />

    <MudText Typo="Typo.body2" Style="font-weight: 600; margin: 0 16px;"> - </MudText>

    <MudNumericField @bind-Value="away" Min="0" Max="20"
                     Style="width: 52px;"
                     Margin="Margin.Dense"
                     Variant="Variant.Text"
                     HideSpinButtons="true"
                     Immediate="true"
                     ReadOnly="@IsReadOnly"
                     Class="@(isSaved && !isEditing ? "tip-field tip-saved" : "tip-field")" />

    @if (isSaved && !isEditing && CanEdit)
    {
        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                       Size="Size.Small"
                       Color="Color.Primary" 
                       OnClick="Edit" />
    }
    else
    {
        <MudIconButton Color="Color.Primary"
                       Size="Size.Small"
                       Icon="@Icons.Material.Filled.Save"
                       OnClick="Save"
                       Disabled="@(IsReadOnly || home is null || away is null)" />
    }
</MudStack>

@code {
    [Parameter] public int MatchId { get; set; }
    [Parameter] public DateTime Kickoff { get; set; }
    [Parameter] public string PlayerName { get; set; }
    [Parameter] public PredictionDto ExistingTip { get; set; }

    private int? home;
    private int? away;
    private bool isSaved;
    private bool isEditing;

    private bool CanEdit => !string.IsNullOrEmpty(PlayerName) && DateTime.UtcNow < Kickoff.AddHours(-1);
    private bool IsReadOnly => !CanEdit || (isSaved && !isEditing);

    protected override void OnParametersSet()
    {
        if (ExistingTip is not null && !isSaved && !isEditing)
        {
            home = ExistingTip.HomeScore;
            away = ExistingTip.AwayScore;
            isSaved = true;
        }
        else if (ExistingTip is null)
        {
            home = null;
            away = null;
            isSaved = false;
            isEditing = false;
        }
    }

    private void Edit()
    {
        isEditing = true;
    }

    private async Task Save()
    {
        await PredictionService.SaveTip(PlayerName, MatchId, home!.Value, away!.Value);
        isSaved = true;
        isEditing = false;
    }
}