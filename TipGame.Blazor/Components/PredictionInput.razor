@using MudBlazor
@using TipGame.Shared.Models

<MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Justify="Justify.FlexEnd">

    <MudStack Spacing="0" AlignItems="AlignItems.Center">
        <MudNumericField @bind-Value="home" Min="0" Max="20"
                         Margin="Margin.Dense"
                         Variant="@(IsReadOnly ? Variant.Text : Variant.Outlined)"
                         HideSpinButtons="true"
                         Immediate="true"
                         ReadOnly="@IsReadOnly"
                         Style="width: 36px;"
                         Class="@(IsReadOnly ? "tip-readonly tip-field tip-bold" : "tip-field tip-bold")" />

        <MudNumericField @bind-Value="away" Min="0" Max="20"
                         Margin="Margin.Dense"
                         Variant="@(IsReadOnly ? Variant.Text : Variant.Outlined)"
                         HideSpinButtons="true"
                         Immediate="true"
                         ReadOnly="@IsReadOnly"
                         Style="width: 36px;"
                         Class="@(IsReadOnly ? "tip-readonly tip-field tip-bold" : "tip-field tip-bold")" />
    </MudStack>

    @if (isSaved && !isEditing && CanEdit)
    {
        <MudIconButton Icon="@Icons.Material.Filled.Edit" 
                       Size="Size.Small"
                       Color="Color.Primary" 
                       OnClick="Edit" />
    }
    else if (CanEdit)
    {
        <MudIconButton Color="Color.Primary"
                       Size="Size.Small"
                       Icon="@Icons.Material.Filled.Save"
                       OnClick="Save"
                       Disabled="@(home is null || away is null)" />
    }
</MudStack>
