@using MudBlazor

<MudDialog @bind-Visible="IsOpen" Options="dialogOptions">
    <TitleContent>
        @if (showAccountView)
        {
            <MudText Typo="Typo.h6">Min konto</MudText>
        }
        else if (isForgotPasswordMode)
        {
            <MudText Typo="Typo.h6">Glemt kodeord</MudText>
        }
        else if (isSignUpMode)
        {
            <MudText Typo="Typo.h6">Opret konto</MudText>
        }
        else
        {
            <MudText Typo="Typo.h6">Log ind</MudText>
        }
    </TitleContent>
    <DialogContent>
        @if (showAccountView)
        {
            <MudStack AlignItems="AlignItems.Center" Spacing="3">
                <MudAvatar Color="Color.Primary" Size="Size.Large">
                    <MudIcon Icon="@Icons.Material.Filled.Person" />
                </MudAvatar>
                <MudStack AlignItems="AlignItems.Center" Spacing="0">
                    <MudText Typo="Typo.h6">@PlayerState.PlayerName</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">@PlayerState.Email</MudText>
                </MudStack>
            </MudStack>
        }
        else if (isForgotPasswordMode)
        {
            @if (forgotPasswordSent)
            {
                <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Icon="@Icons.Material.Filled.MarkEmailRead">
                    Hvis der findes en konto med <strong>@forgotPasswordEmail</strong>, har vi sendt en e-mail med et link til at nulstille dit kodeord. Tjek også din spam-mappe.
                </MudAlert>
            }
            else
            {
                <MudStack Spacing="2">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Indtast din e-mail, så sender vi dig et link til at nulstille dit kodeord.
                    </MudText>
                    <MudTextField @bind-Value="forgotPasswordEmail"
                                  Label="Email"
                                  InputType="InputType.Email"
                                  Variant="Variant.Text"
                                  Immediate="true"
                                  OnKeyDown="HandleForgotPasswordKey" />
                </MudStack>
            }

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="mt-4">
                <MudLink Typo="Typo.body2" Color="Color.Primary" OnClick="@(() => { isForgotPasswordMode = false; forgotPasswordSent = false; })">
                    Tilbage til login
                </MudLink>
            </MudStack>
        }
        else if (isSignUpMode)
        {
            <MudStack Spacing="2">
                <MudStack Row="true" Spacing="2">
                    <MudTextField @bind-Value="signUpFirstName"
                                  Label="Fornavn"
                                  Variant="Variant.Text"
                                  Immediate="true" />
                    <MudTextField @bind-Value="signUpLastName"
                                  Label="Efternavn"
                                  Variant="Variant.Text"
                                  Immediate="true" />
                </MudStack>
                <MudTextField @bind-Value="signUpEmail"
                              Label="Email"
                              InputType="InputType.Email"
                              Variant="Variant.Text"
                              Immediate="true" />
                <MudTextField @bind-Value="signUpPassword"
                              Label="Kodeord"
                              InputType="InputType.Password"
                              Variant="Variant.Text"
                              Immediate="true" />
            </MudStack>

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="mt-4">
                <MudText Typo="Typo.body2">Har du allerede en konto?</MudText>
                <MudLink Typo="Typo.body2" Color="Color.Primary" OnClick="@(() => isSignUpMode = false)">
                    Log ind
                </MudLink>
            </MudStack>
        }
        else
        {
            <MudStack Spacing="2">
                <MudTextField @bind-Value="emailInput"
                              Label="Email"
                              InputType="InputType.Email"
                              Variant="Variant.Text"
                              Immediate="true"
                              OnKeyDown="HandleLoginKey" />
                <MudTextField @bind-Value="passwordInput"
                              Label="Kodeord"
                              InputType="InputType.Password"
                              Variant="Variant.Text"
                              Immediate="true"
                              OnKeyDown="HandleLoginKey" />
            </MudStack>

            <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-1">
                <MudLink Typo="Typo.caption" Color="Color.Primary" OnClick="@(() => { isForgotPasswordMode = true; forgotPasswordEmail = emailInput; forgotPasswordSent = false; })">
                    Glemt kodeord?
                </MudLink>
            </MudStack>

            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.Center" Class="mt-4">
                <MudText Typo="Typo.body2">Har du ikke en konto?</MudText>
                <MudLink Typo="Typo.body2" Color="Color.Primary" OnClick="@(() => isSignUpMode = true)">
                    Opret nu
                </MudLink>
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        @if (showAccountView)
        {
            <MudButton OnClick="Close">Luk</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.Logout"
                       OnClick="HandleLogout">
                Log ud
            </MudButton>
        }
        else if (isForgotPasswordMode)
        {
            <MudButton OnClick="Close">Luk</MudButton>
            @if (!forgotPasswordSent)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           OnClick="HandleForgotPassword"
                           Disabled="@(string.IsNullOrWhiteSpace(forgotPasswordEmail) || isSendingResetEmail)">
                    @(isSendingResetEmail ? "Sender…" : "Send nulstillingslink")
                </MudButton>
            }
        }
        else if (isSignUpMode)
        {
            <MudButton OnClick="Close">Annuller</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="HandleSignUp"
                       Disabled="@(string.IsNullOrWhiteSpace(signUpFirstName) || string.IsNullOrWhiteSpace(signUpLastName) || string.IsNullOrWhiteSpace(signUpEmail) || string.IsNullOrWhiteSpace(signUpPassword))">
                Opret konto
            </MudButton>
        }
        else
        {
            <MudButton OnClick="Close">Annuller</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="HandleLogin"
                       Disabled="@(string.IsNullOrWhiteSpace(emailInput) || string.IsNullOrWhiteSpace(passwordInput))">
                Log ind
            </MudButton>
        }
    </DialogActions>
</MudDialog>
