@using MudBlazor

<MudPaper Class="pa-6" Elevation="0">
    <MudText Typo="Typo.h6" Class="mb-2">⚔️ Head-to-head</MudText>
    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-6">
        Sammenlign to spillere kamp for kamp.
    </MudText>

    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="5">
            <MudSelect T="string" Label="Spiller 1" @bind-Value="Player1" Variant="Variant.Outlined" Dense="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person">
                @foreach (var name in PlayerNames)
                {
                    <MudSelectItem Value="@name">@name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex align-center justify-center">
            <MudText Typo="Typo.h6" Color="Color.Default">vs</MudText>
        </MudItem>
        <MudItem xs="12" sm="5">
            <MudSelect T="string" Label="Spiller 2" @bind-Value="Player2" Variant="Variant.Outlined" Dense="true" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person">
                @foreach (var name in PlayerNames)
                {
                    <MudSelectItem Value="@name">@name</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
    </MudGrid>

    @if (!string.IsNullOrEmpty(Player1) && !string.IsNullOrEmpty(Player2) && Player1 != Player2)
    {
        @* --- Scoreboard --- *@
        <MudPaper Class="pa-5 rounded-xl mb-5" Elevation="1">
            <MudStack Row="true" Justify="Justify.SpaceAround" AlignItems="AlignItems.Center">
                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudAvatar Color="@(GetTotal(Player1) >= GetTotal(Player2) ? Color.Primary : Color.Default)"
                               Size="Size.Large" Variant="Variant.Filled">
                        @Player1![..1].ToUpper()
                    </MudAvatar>
                    <MudText Typo="Typo.subtitle1">@Player1</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Primary">@GetTotal(Player1)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">point</MudText>
                </MudStack>

                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Size="Size.Small">@GetWins(Player1, Player2) V</MudChip>
                    <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small">@GetDraws() U</MudChip>
                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Text" Size="Size.Small">@GetWins(Player2, Player1) V</MudChip>
                </MudStack>

                <MudStack AlignItems="AlignItems.Center" Spacing="1">
                    <MudAvatar Color="@(GetTotal(Player2) >= GetTotal(Player1) ? Color.Secondary : Color.Default)"
                               Size="Size.Large" Variant="Variant.Filled">
                        @Player2![..1].ToUpper()
                    </MudAvatar>
                    <MudText Typo="Typo.subtitle1">@Player2</MudText>
                    <MudText Typo="Typo.h4" Color="Color.Secondary">@GetTotal(Player2)</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Default">point</MudText>
                </MudStack>
            </MudStack>

            @* Win distribution bar *@
            @if (MatchIds.Count > 0)
            {
                <MudStack Row="true" Class="mt-4 rounded-pill overflow-hidden" Style="height: 8px;">
                    <div style="flex: @GetWins(Player1, Player2); background: var(--mud-palette-primary); transition: flex 0.3s;"></div>
                    <div style="flex: @GetDraws(); background: var(--mud-palette-text-disabled); transition: flex 0.3s;"></div>
                    <div style="flex: @GetWins(Player2, Player1); background: var(--mud-palette-secondary); transition: flex 0.3s;"></div>
                </MudStack>
            }
        </MudPaper>

        @* --- Kamp-for-kamp liste --- *@
        <MudText Typo="Typo.subtitle2" Class="mb-2" Color="Color.Default">Kamp for kamp</MudText>
        <MudStack Spacing="2">
            @foreach (var match in GetMatchResults())
            {
                <MudPaper Class="pa-3 rounded-lg" Elevation="0" Outlined="true">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="flex: 1; justify-content: flex-start;">
                            @if (match.P1Points > match.P2Points)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Primary" Size="Size.Small" />
                            }
                            <MudChip T="string" Color="@(match.P1Points > match.P2Points ? Color.Primary : match.P1Points == match.P2Points ? Color.Default : Color.Default)"
                                     Variant="@(match.P1Points > match.P2Points ? Variant.Filled : Variant.Outlined)"
                                     Size="Size.Small">
                                @match.P1Points pt
                            </MudChip>
                        </MudStack>

                        <MudText Typo="Typo.body2" Align="Align.Center" Style="flex: 2; text-align: center;">
                            @match.Label
                        </MudText>

                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Style="flex: 1; justify-content: flex-end;">
                            <MudChip T="string" Color="@(match.P2Points > match.P1Points ? Color.Secondary : match.P1Points == match.P2Points ? Color.Default : Color.Default)"
                                     Variant="@(match.P2Points > match.P1Points ? Variant.Filled : Variant.Outlined)"
                                     Size="Size.Small">
                                @match.P2Points pt
                            </MudChip>
                            @if (match.P2Points > match.P1Points)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.EmojiEvents" Color="Color.Secondary" Size="Size.Small" />
                            }
                        </MudStack>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    }
    else if (Player1 == Player2 && !string.IsNullOrEmpty(Player1))
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">Vælg to forskellige spillere.</MudAlert>
    }
    else
    {
        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Icon="@Icons.Material.Filled.Info">
            Vælg to spillere ovenfor for at sammenligne deres præstationer.
        </MudAlert>
    }
</MudPaper>
