@using MudBlazor

<MudPaper Class="pa-6" Elevation="0">
    <MudText Typo="Typo.h6" Class="mb-2">📈 Point-udvikling</MudText>
    <MudText Typo="Typo.body2" Color="Color.Default" Class="mb-6">
        Akkumulerede point per spiller over kampdage. Tryk på navnene for at filtrere.
    </MudText>

    @if (Series.Count > 0)
    {
        @* --- Aktuel stilling kort --- *@
        <MudPaper Class="pa-4 rounded-xl mb-5" Elevation="1">
            <MudStack Row="true" Justify="Justify.Center" AlignItems="AlignItems.End" Spacing="4" Style="flex-wrap: wrap;">
                @foreach (var (player, index) in GetCurrentStandings())
                {
                    var rank = index + 1;
                    var isLeader = rank == 1;
                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                        @if (isLeader)
                        {
                            <MudText Typo="Typo.h4">👑</MudText>
                        }
                        <MudAvatar Color="@(isLeader ? Color.Primary : Color.Default)"
                                   Size="@(isLeader ? Size.Large : Size.Medium)"
                                   Variant="Variant.Filled">
                            @player.Name[..1].ToUpper()
                        </MudAvatar>
                        <MudText Typo="@(isLeader ? Typo.h5 : Typo.h6)"
                                 Color="@(isLeader ? Color.Primary : Color.Default)">
                            @player.CurrentPoints
                        </MudText>
                        <MudText Typo="Typo.caption">@player.Name</MudText>
                    </MudStack>
                }
            </MudStack>
        </MudPaper>

        @* --- Filter chips --- *@
        <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap" Class="mb-4">
            @foreach (var name in allNames)
            {
                var n = name;
                var active = visibleNames.Contains(n);
                <MudChip T="string"
                         Text="@n"
                         Size="Size.Small"
                         Variant="@(active ? Variant.Filled : Variant.Outlined)"
                         Color="Color.Primary"
                         OnClick="@(() => TogglePlayer(n))" />
            }
        </MudStack>

        @* --- Line chart --- *@
        <MudChart ChartType="ChartType.Line"
                  ChartSeries="@filteredSeries"
                  ChartLabels="@Labels"
                  ChartOptions="@lineOptions"
                  MatchBoundsToSize="true"
                  Height="350px"
                  @bind-SelectedIndex="selectedIndex"
                  Class="mt-2" />
    }
    else
    {
        <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Icon="@Icons.Material.Filled.Info">
            Ingen data endnu.
        </MudAlert>
    }
</MudPaper>
